    "version": "0.2.0",
    "configurations": [

        {
            "name": "Development server",
            "type": "debugpy",
            "request": "launch",
            "module": "app"
        },
        {
            "name": "Waitress WSGI",
            "type": "debugpy",
            "request": "launch",
            "module": "waitress",
            "args": [
                "--listen=127.0.0.1:3000",
                "wsgi:app"
            ]
        }
    ]
}